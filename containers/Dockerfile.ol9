# KubeXM Build Container - Oracle Linux 9
# Purpose: Build RPM packages and local repository for Oracle Linux 9

FROM oraclelinux:9

LABEL maintainer="KubeXM Team"
LABEL description="Oracle Linux 9 build environment for KubeXM offline packages"
LABEL os.type="ol"
LABEL os.version="9"
LABEL pkg.manager="dnf"

# Install build tools
RUN dnf install -y \
    dnf-plugins-core \
    createrepo_c \
    rpm-build \
    wget \
    curl \
    tar \
    gzip \
    xz \
    && dnf clean all

# Create build directories
RUN mkdir -p /build/packages /build/repo /build/output

WORKDIR /build

# Copy build scripts
COPY containers/scripts/build-rpm.sh /build-rpm.sh
RUN chmod +x /build-rpm.sh

# Default command
CMD ["/bin/bash"]
