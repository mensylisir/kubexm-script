# ==============================================================================
# Etcd Configuration File
# ==============================================================================
# Generated by KubeXM Script
# Cluster: ${CLUSTER_NAME}
# Node: ${NODE_NAME}
# ==============================================================================

name: '${NODE_NAME}'
data-dir: '${ETCD_DATA_DIR}'
wal-dir: ''

# --- 快照与压缩 (生产优化) ---
snapshot-count: ${ETCD_SNAPSHOT_COUNT}
auto-compaction-retention: '${ETCD_AUTO_COMPACTION_RETENTION}'
auto-compaction-mode: '${ETCD_AUTO_COMPACTION_MODE}'
quota-backend-bytes: ${ETCD_QUOTA_BACKEND_BYTES}
max-wals: ${ETCD_MAX_WALS}

# --- 监听地址 (修改为本机 IP) ---
listen-peer-urls: 'https://${NODE_IP}:2380'
listen-client-urls: 'https://${NODE_IP}:2379,https://127.0.0.1:2379'

# --- 广播地址 (修改为本机 IP，用于告诉其他节点怎么连我) ---
initial-advertise-peer-urls: 'https://${NODE_IP}:2380'
advertise-client-urls: 'https://${NODE_IP}:2379'

# --- 集群初始化配置 ---
initial-cluster: '${ETCD_INITIAL_CLUSTER}'
initial-cluster-token: '${ETCD_CLUSTER_TOKEN}'
initial-cluster-state: '${ETCD_INITIAL_STATE}'  # 首次初始化为 'new'，加入现有集群为 'existing'

# --- Client 安全配置 (对应 server 证书) ---
client-transport-security:
  cert-file: '/etc/etcd/ssl/server.crt'
  key-file: '/etc/etcd/ssl/server.key'
  trusted-ca-file: '/etc/etcd/ssl/ca.crt'
  client-cert-auth: true

# --- Peer 安全配置 (对应 peer 证书) ---
peer-transport-security:
  cert-file: '/etc/etcd/ssl/peer.crt'
  key-file: '/etc/etcd/ssl/peer.key'
  trusted-ca-file: '/etc/etcd/ssl/ca.crt'
  client-cert-auth: true

# --- 调试与日志 ---
logger: 'zap'
log-level: '${ETCD_LOG_LEVEL}'

# --- 性能调优参数 ---
heartbeat-interval: '${ETCD_HEARTBEAT_INTERVAL}'
election-timeout: '${ETCD_ELECTION_TIMEOUT}'

# --- 度量与监控 ---
listen-metrics-urls: 'http://0.0.0.0:2381'

# --- 认证 (可选，如需要启用Etcd认证) ---
# auth:
#   token: 'jwt:public-key,private-key,sign-method,expire-after'
