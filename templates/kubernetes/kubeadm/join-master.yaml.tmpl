# ==============================================================================
# Kubeadm Join Configuration for Additional Master Nodes
# ==============================================================================
# Generated by KubeXM build system
# Cluster: ${CLUSTER_NAME}
# Node: ${NODE_NAME}
# ==============================================================================

---
apiVersion: kubeadm.k8s.io/v1beta3
kind: JoinConfiguration
discovery:
  bootstrapToken:
    apiServerEndpoint: ${APISERVER_ENDPOINT}
    token: ${BOOTSTRAP_TOKEN}
    caCertHashes:
    - "sha256:${CA_CERT_HASH}"
  tlsBootstrapToken: ${TLS_BOOTSTRAP_TOKEN}
controlPlane:
  localAPIEndpoint:
    advertiseAddress: ${NODE_IP}
    bindPort: 6443
  certificateKey: ${CERTIFICATE_KEY}
nodeRegistration:
  criSocket: ${CRI_SOCKET}
  name: ${NODE_NAME}
  kubeletExtraArgs:
    node-ip: ${NODE_IP}
    hostname-override: ${NODE_NAME}
    cgroup-driver: ${CGROUP_DRIVER:-systemd}
  taints:
  - effect: NoSchedule
    key: node-role.kubernetes.io/control-plane