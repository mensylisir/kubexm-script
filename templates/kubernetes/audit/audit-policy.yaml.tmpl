# ==============================================================================
# Kubernetes API Server Audit Policy
# ==============================================================================
# Generated by KubeXM Script
# Cluster: ${CLUSTER_NAME}
# ==============================================================================

apiVersion: audit.k8s.io/v1
kind: Policy
rules:
  # 级别为 None 的事件（不记录）
  - level: None
    omitStages:
      - "RequestReceived"

  # 系统组件的 watch 请求（减少日志噪音）
  - level: None
    users: ["system:kube-proxy", "system:apiserver", "system:controller-manager", "system:scheduler"]
    verbs: ["watch"]
    resources:
      - group: ""
        resources: ["endpoints", "services", "services/status"]

  # Secret和ConfigMap的元数据访问
  - level: Metadata
    resources:
      - group: ""
        resources: ["secrets", "configmaps", "serviceaccounts/token"]

  # 记录所有写操作（创建、更新、删除等）
  - level: RequestResponse
    verbs: ["create", "update", "patch", "delete", "deletecollection"]

  # 读取操作记录元数据
  - level: Metadata
    verbs: ["get", "list", "watch"]

  # 记录所有节点和Pod相关的操作
  - level: Request
    resources:
      - group: ""
        resources: ["nodes", "nodes/status", "pods", "pods/status", "services", "endpoints"]

  # 记录所有认证和授权相关的请求
  - level: Metadata
    resources:
      - group: "rbac.authorization.k8s.io"
        resources: ["roles", "rolebindings", "clusterroles", "clusterrolebindings"]
      - group: "authentication.k8s.io"
        resources: ["tokenreviews"]
      - group: "authorization.k8s.io"
        resources: ["subjectaccessreviews"]
