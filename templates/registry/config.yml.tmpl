version: 0.1
log:
  level: info
  formatter: text
  fields:
    service: registry

storage:
  cache:
    blobdescriptor: inmemory
  filesystem:
    rootdirectory: ${REGISTRY_DATA_DIR:-/var/lib/registry}
  delete:
    enabled: true

http:
  addr: 0.0.0.0:${REGISTRY_PORT:-5000}
  headers:
    X-Content-Type-Options: [nosniff]
  debug:
    addr: 0.0.0.0:5001
    prometheus:
      enabled: true
      path: /metrics

health:
  storagedriver:
    enabled: true
    interval: 10s
    threshold: 3
