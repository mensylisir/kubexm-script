apiVersion: v1
kind: Pod
metadata:
  name: nginx-lb
  namespace: kube-system
  labels:
    app: nginx-lb
spec:
  containers:
  - name: nginx
    image: nginx:1.20-alpine
    ports:
    - containerPort: 80
      hostPort: 80
    - containerPort: 443
      hostPort: 443
    volumeMounts:
    - name: conf
      mountPath: /etc/nginx/nginx.conf
      subPath: nginx.conf
  volumes:
  - name: conf
    hostPath:
      path: /etc/kubernetes/manifests/nginx.conf
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: nginx-lb-config
  namespace: kube-system
data:
  nginx.conf: |
    events {
        worker_connections 1024;
    }
    stream {
        upstream kube_apiserver {
{{- range .BackendServers }}
            server {{ .Host }}:{{ .Port }};
{{- end }}
        }
        server {
            listen 127.0.0.1:6443;
            proxy_pass kube_apiserver;
        }
    }
